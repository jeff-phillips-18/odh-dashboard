APP_ENV=development

BACKEND_PORT=4000
FRONTEND_PORT=4010
FASTIFY_LOG_LEVEL=debug

############### Dev install settings, specify in .env.development.local to override ###############
OC_PROJECT=opendatahub        # specify in .env.local to override
DASHBOARD_APP=odh-dashboard  # specify in .env.local to override
CONTAINER_BUILDER=docker
IMAGE_REPOSITORY=quay.io/opendatahub/odh-dashboard:latest
SOURCE_REPOSITORY_URL=git@github.com:opendatahub-io/odh-dashboard.git
SOURCE_REPOSITORY_REF=master
